{
  "name": "client-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:mobile": "ng build --configuration mobile",
    "cap:sync": "npm run build:mobile && npx cap sync",
